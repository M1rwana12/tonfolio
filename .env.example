# PostgreSQL — matches docker-compose defaults
DATABASE_URL=postgresql://tonfolio:tonfolio@localhost:5432/tonfolio

# Redis
REDIS_URL=redis://localhost:6379

# Telegram bot token from @BotFather
BOT_TOKEN=0000000000:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA

# tonapi.io API key (https://tonconsole.com)
TONAPI_KEY=your-tonapi-key

# CoinGecko API key (demo tier is enough)
COINGECKO_API_KEY=your-coingecko-key

# Public URL of the Mini App
WEB_APP_URL=http://localhost:3000
