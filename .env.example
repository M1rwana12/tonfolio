# PostgreSQL — matches docker-compose defaults
DATABASE_URL=postgresql://tonfolio:tonfolio@localhost:5432/tonfolio

# Redis (BullMQ jobs, price cache, alert locks)
REDIS_URL=redis://localhost:6379

# Telegram bot token from @BotFather
BOT_TOKEN=0000000000:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA

# tonapi.io API key (https://tonconsole.com) — optional, raises rate limits
TONAPI_KEY=

# CoinGecko API key (demo tier is enough) — optional
COINGECKO_API_KEY=

# Public origin of the Mini App (ton_proof domain check, inline buttons).
# Leave empty in local dev — the "Open Mini App" button requires a real
# https:// origin and stays hidden otherwise.
APP_URL=
WEB_APP_URL=

# Dev only: "1" enables header-based auth bypass for local runs and e2e.
# NEVER set in production.
ALLOW_DEV_AUTH=
NEXT_PUBLIC_ALLOW_DEV_AUTH=
NEXT_PUBLIC_DEV_TELEGRAM_ID=
