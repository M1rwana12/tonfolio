{
  "name": "tonfolio",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.6.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "build": "pnpm -r build",
    "db:generate": "pnpm --filter @tonfolio/db db:generate",
    "db:push": "pnpm --filter @tonfolio/db db:push",
    "db:migrate": "pnpm --filter @tonfolio/db db:migrate",
    "db:seed": "pnpm --filter @tonfolio/db db:seed"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.0",
    "eslint": "^9.30.0",
    "eslint-config-prettier": "^10.1.0",
    "prettier": "^3.6.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.35.0"
  }
}
